{
  "name": "front",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "update:search-box-dom-comment": "node scripts/update-search-box-dom-comment.js",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "seed": "npx tsx src/foo/seed.ts"
  },
  "devDependencies": {
    "@pgtyped/cli": "^2.4.3",
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/adapter-static": "^3.0.9",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.3.0",
    "@types/uuid": "^10.0.0",
    "@vitest/browser": "^3.2.3",
    "daisyui": "^5.5.19",
    "msw": "^2.10.5",
    "playwright": "^1.53.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.3",
    "vitest-browser-svelte": "^0.1.0"
  },
  "pretter": {
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "dependencies": {
    "@pgtyped/runtime": "^2.4.2",
    "dexie": "^4.2.0",
    "dompurify": "^3.2.6",
    "highlight.js": "^11.11.1",
    "lodash-es": "^4.17.21",
    "marked": "^17.0.4",
    "marked-highlight": "^2.2.3",
    "pino": "^9.9.0",
    "zod": "^3.24.0"
  },
  "msw": {
    "workerDirectory": [
      "public",
      "static"
    ]
  }
}
